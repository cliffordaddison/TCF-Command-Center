{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's study profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "notificationHour": { "type": "number" }
          }
        },
        "startDate": { "type": "string", "format": "date-time" },
        "targetExamDate": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "startDate", "targetExamDate"]
    },
    "StudyPlanTemplate": {
      "title": "Study Plan Template",
      "description": "Master list of all 180 days of tasks",
      "type": "object",
      "properties": {
        "day": { "type": "number" },
        "dateOffset": { "type": "number" },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "resourceLink": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["day", "dateOffset", "tasks"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks what the user actually did",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "dayNumber": { "type": "number" },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "completed": { "type": "boolean" },
              "timeSpent": { "type": "number" }
            }
          }
        },
        "dateCompleted": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "dayNumber", "tasks"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/studyPlanTemplate/{dayId}": {
      "schema": "StudyPlanTemplate",
      "description": "Master study plan template"
    },
    "/users/{userId}/progress/{progressId}": {
      "schema": "UserProgress",
      "description": "User-specific study progress"
    }
  }
}
