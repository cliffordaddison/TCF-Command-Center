rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - settings: map { notificationHour: number }
    //   - startDate: string (ISO 8601)
    //   - targetExamDate: string (ISO 8601)
    //
    // Collection: studyPlanTemplate
    // Document ID: {dayId}
    // Fields:
    //   - day: number (required)
    //   - dateOffset: number (required)
    //   - tasks: list of maps { id, type, title, description, resourceLink, completed }
    //
    // Collection: users/{userId}/progress
    // Document ID: {progressId}
    // Fields:
    //   - userId: string (required)
    //   - dayNumber: number (required)
    //   - tasks: list of maps { id, completed, timeSpent }
    //   - dateCompleted: string (ISO 8601)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email == "clifford.siisi.addison@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
        );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /progress/{progressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /studyPlanTemplate/{dayId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
